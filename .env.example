# Claude model alias (default: sonnet)
CLAUDE_MODEL=sonnet

# Server port (default: 4001)
PORT=4001

# Provider credentials (server-managed — never exposed to callers)

# Claude: OAuth token read directly by Claude Agent SDK
CLAUDE_CODE_OAUTH_TOKEN=

# Codex: Full content of ~/.codex/auth.json (obtained via `codex login` on local machine)
# Format: {"auth_mode":"chatgpt","tokens":{"access_token":"...","id_token":"...","refresh_token":"..."},"last_refresh":"..."}
CODEX_AUTH_JSON=
