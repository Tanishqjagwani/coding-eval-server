# Required: HuggingFace inference endpoint
HF_URL=https://your-hf-endpoint.endpoints.huggingface.cloud/v1/chat/completions
HF_MODEL=your-model-name

# Optional: HuggingFace API key (if endpoint requires auth)
HF_API_KEY=

# Server port (default: 4001)
PORT=4001

# Required: Claude Code OAuth token (used by Claude Agent SDK)
CLAUDE_CODE_OAUTH_TOKEN=
